FROM python:3.11-slim

WORKDIR /app

COPY backend/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ ./backend/
COPY alembic.ini ./

RUN mkdir -p /app/uploads /app/data

EXPOSE 8000

CMD ["sh", "-c", "python -m alembic upgrade head && python -m backend.scripts.seed_demo || true && uvicorn backend.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
