  SECRET_KEY: "CHANGE_ME_USE_OPENSSL_RAND_HEX_32"
  GEMINI_API_KEY: "CHANGE_ME"
  GEMINI_MODEL: "gemini-2.5-flash"
  GEMINI_FALLBACK_MODELS: "gemini-2.0-flash,gemini-1.5-flash"
  MINIO_ROOT_USER: "pipelineiq"
  MINIO_ROOT_PASSWORD: "CHANGE_ME_USE_OPENSSL_RAND_HEX_16"
  S3_ACCESS_KEY: "pipelineiq"
  S3_SECRET_KEY: "CHANGE_ME_USE_OPENSSL_RAND_HEX_16"
