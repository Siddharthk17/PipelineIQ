apiVersion: v1
kind: Secret
metadata:
  name: pipelineiq-secrets
  namespace: pipelineiq
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://pipelineiq:CHANGE_ME@postgres:5432/pipelineiq"
  DATABASE_WRITE_URL: "postgresql+asyncpg://pipelineiq:CHANGE_ME@postgres:5432/pipelineiq"
  DATABASE_READ_URL: "postgresql+asyncpg://pipelineiq:CHANGE_ME@postgres:5432/pipelineiq"
