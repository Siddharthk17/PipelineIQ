# PipelineIQ Environment Configuration

# Application
APP_NAME=PipelineIQ
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./pipelineiq.db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL defaults to REDIS_URL if not set
# CELERY_RESULT_BACKEND defaults to REDIS_URL if not set

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=52428800

# Pipeline Execution
MAX_PIPELINE_STEPS=50
MAX_ROWS_PER_FILE=1000000
STEP_TIMEOUT_SECONDS=300

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]
